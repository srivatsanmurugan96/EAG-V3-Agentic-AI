{
  "manifest_version": 3,
  "name": "Focus Guard",
  "version": "1.0",
  "description": "Stay focused by allowing only predefined websites. Block distractions with style.",
  "permissions": [
    "tabs",
    "storage",
    "activeTab",
    "scripting",
    "webNavigation",
    "alarms"
  ],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Focus Guard"
  },
  "background": {
    "service_worker": "background.js"
  }
}
